# OS / Finder / IDE noise
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.iml
*.swp
*~

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.env
.env.*
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Node / JS
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# Build artifacts
dist/
build/
target/
out/
bin/
obj/
*.o
*.obj
*.so
*.dylib
*.exe

# Rust
**/target/
# Cargo.lock is intentionally NOT ignored — commit it for binaries.

# Matlab
*.asv
slprj/
# Note: *.mat NOT ignored by default. If you have huge .mat data files, add
# them per-repo with `echo 'data/*.mat' >> .gitignore` before the first commit.

# Xcode / Objective-C
xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/
*.xcuserstate
*.pbxuser
*.mode1v3
*.mode2v3

# Jupyter
*.ipynb_checkpoints

# Logs
*.log
logs/

# Secrets — never push these
*.pem
*.key
*.pfx
secrets.json
api_keys.txt
credentials.json
.aws/
.ssh/

# Local databases
*.sqlite
*.sqlite3
*.db

# Local data dumps (if you have large data, prefer git-lfs)
*.parquet
*.feather

# This sync system's own log
sync.log
